<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="#333333"
    android:gravity="center"
    tools:context=".MainActivity">

    <!-- Screen (Left) -->
    <TextView
        android:id="@+id/display"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/display_background"
        android:gravity="end|bottom"
        android:padding="24dp"
        android:text="0"
        android:textColor="#000000"
        android:textSize="56sp"
        android:layout_marginEnd="16dp"/>

    <!-- Buttons (Right) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Row 1: % Sqrt Square Power -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPercent"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="%"
                android:textSize="18sp"
                android:textColor="#000000"
                android:background="@drawable/btn_func"
                app:backgroundTint="@null"/>

            <ImageButton
                android:id="@+id/btnSquareRoot"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:contentDescription="Square Root"
                android:scaleType="fitCenter"
                android:padding="16dp"
                android:src="@drawable/ic_sqrt"
                android:background="@drawable/btn_func"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnSquare"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="x²"
                android:textSize="18sp"
                android:textColor="#000000"
                android:background="@drawable/btn_func"
                app:backgroundTint="@null"/>

            <ImageButton
                android:id="@+id/btnBackspace"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:contentDescription="Backspace"
                android:scaleType="fitCenter"
                android:padding="16dp"
                android:src="@drawable/ic_backspace"
                android:background="@drawable/btn_func"
                app:backgroundTint="@null"/>
        </LinearLayout>

        <!-- Row 2: M+ M- C AC -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMPlus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="M+"
                android:textSize="18sp"
                android:textColor="#000000"
                android:background="@drawable/btn_func"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnMMinus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="M-"
                android:textSize="18sp"
                android:textColor="#000000"
                android:background="@drawable/btn_func"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="C"
                android:textSize="18sp"
                android:textColor="#000000"
                android:background="@drawable/btn_func"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnA"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="AC"
                android:textSize="18sp"
                android:textColor="#000000"
                android:background="@drawable/btn_func"
                app:backgroundTint="@null"/>
        </LinearLayout>

        <!-- Row 3: 7 8 9 / -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn7"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="7"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_num"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btn8"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="8"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_num"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btn9"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="9"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_num"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnDivide"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="÷"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_op"
                app:backgroundTint="@null"/>
        </LinearLayout>

        <!-- Row 4: 4 5 6 x -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="4"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_num"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btn5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="5"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_num"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btn6"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="6"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_num"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnMultiply"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="×"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_op"
                app:backgroundTint="@null"/>
        </LinearLayout>

        <!-- Row 5: 1 2 3 - -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="1"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_num"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btn2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="2"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_num"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btn3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="3"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_num"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnSubtract"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="-"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_op"
                app:backgroundTint="@null"/>
        </LinearLayout>

        <!-- Row 6: 0 . = + -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:layout_margin="3dp"
                android:text="0"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_num"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnDecimal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="."
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_num"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnEquals"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="="
                android:textSize="18sp"
                android:textColor="#000000"
                android:background="@drawable/btn_eq"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnAdd"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="3dp"
                android:text="+"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_op"
                app:backgroundTint="@null"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
